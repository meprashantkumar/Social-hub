# ---- Server ----
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ---- Database (matches docker-compose Postgres) ----
DATABASE_URL=postgres://app:devpassword@localhost:5432/socialhub

# ---- Auth / JWT ----
# Generate strong secrets for production, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_16_chars_0123456789
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_16_chars_0123456789
ACCESS_TOKEN_TTL_SECONDS=900        # 15 minutes
REFRESH_TOKEN_TTL_DAYS=30

# Set to true only when serving over HTTPS (production)
COOKIE_SECURE=false
# lax = same-site (dev, or app+api on same domain). Use "none" (auto-forces Secure)
# only if the SPA and API are on genuinely different sites in production.
COOKIE_SAMESITE=lax

# ---- Connections / OAuth ----
ENCRYPTION_KEY=            # 64 hex chars (32 bytes): openssl rand -hex 32
OAUTH_STATE_SECRET=        # any strong random string (>=16 chars)
API_BASE_URL=http://localhost:4000

# YouTube (Google Cloud Console -> OAuth 2.0 Client ID; add redirect URI
# http://localhost:4000/api/connections/oauth/youtube/callback)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ---- Cloudinary (media uploads) ----
# From your Cloudinary dashboard. Leave blank to disable uploads (the app still runs).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Instagram (Meta "API setup with Instagram business login") ----
# Instagram App ID + Secret; redirect URI http://localhost:4000/api/connections/oauth/instagram/callback
# Note: Instagram requires an HTTPS redirect URL, so local testing needs a tunnel
# (e.g. cloudflared) — point API_BASE_URL + CLIENT_ORIGIN at the tunnel while testing IG.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ---- LinkedIn ----
# LinkedIn Developer app (https://www.linkedin.com/developers/apps) with products
# "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn".
# Redirect URL: http://localhost:4000/api/connections/oauth/linkedin/callback (localhost is allowed).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Monthly version (YYYYMM) for LinkedIn's versioned Posts/Images API; bump if deprecated.
LINKEDIN_API_VERSION=202506

# ---- X (Twitter) ----
# X Developer app (https://developer.x.com) with OAuth 2.0 User Auth set up as a
# "Web App, Automated App or Bot" (confidential client → has a client secret).
# Callback URL: http://localhost:4000/api/connections/oauth/x/callback (localhost is allowed).
# Requires scopes tweet.write, users.read, media.write, offline.access.
X_CLIENT_ID=
X_CLIENT_SECRET=

# Scheduler poll interval (seconds); 0 disables
SCHEDULER_INTERVAL_SECONDS=30
